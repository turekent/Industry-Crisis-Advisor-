# ===========================================
# Environment Variables Configuration
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# LLM API Configuration (Required)
# -------------------------------------------
# Get your API key from Coze platform
COZE_WORKLOAD_IDENTITY_API_KEY=your_coze_api_key_here
COZE_INTEGRATION_MODEL_BASE_URL=https://api.coze.cn

# -------------------------------------------
# Price API Keys (Optional)
# -------------------------------------------
# Professional price data APIs
# If not configured, system will use web search instead

# Brent Crude Oil API
BRENT_CRUDE_API_KEY=your_brent_api_key_here

# LME Copper Price API
LME_COPPER_API_KEY=your_lme_copper_api_key_here

# Palladium Spot Price API
PALLADIUM_API_KEY=your_palladium_api_key_here

# SCFI Container Freight Index API
SCFI_API_KEY=your_scfi_api_key_here

# Shanghai Aluminum Futures API
SHFE_ALUMINUM_API_KEY=your_shfe_aluminum_api_key_here

# Gold Spot Price API
GOLD_API_KEY=your_gold_api_key_here

# -------------------------------------------
# Application Settings (Optional)
# -------------------------------------------
# Server port (default: 5000)
PORT=5000

# Debug mode (default: false)
DEBUG=false

# Log level (default: INFO)
LOG_LEVEL=INFO

# -------------------------------------------
# Security Settings (Optional)
# -------------------------------------------
# Secret key for session encryption
SECRET_KEY=your_secret_key_here

# Allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
